# SentinelAI Configuration

# Core API Server
API_PORT=8000
JWT_SECRET=supersecretjwttokenchangeinproduction12345
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Database
# For local development without Docker Postgres, you can use: sqlite:///./sentinelai.db
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/sentinelai

# Redis (used for Celery and caching)
REDIS_URL=redis://localhost:6379/0

# WAF Proxy Settings
WAF_PROXY_PORT=8080
DEFAULT_BLOCK_THRESHOLD=50
FAIL_SAFE_OPEN=true

# AI Provider (Gemini)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-flash

# SMTP Email Settings (Alerts)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=alerts@sentinelai.com
SMTP_PASSWORD=yoursmtppassword
SMTP_FROM_EMAIL=no-reply@sentinelai.com

# GitHub & GitLab OAuth (for repository syncing)
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
GITLAB_CLIENT_ID=your_gitlab_client_id
GITLAB_CLIENT_SECRET=your_gitlab_client_secret
